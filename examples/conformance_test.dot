// ABOUTME: Attractor-independent conformance test pipeline.
// ABOUTME: Exercises core spec features: linear flow, branching, goal gates, retry, parallel, and context.
digraph ConformanceTest {
  graph [
    goal="Verify attractor implementation handles core spec features correctly.",
    label="Attractor Conformance Test",
    rankdir=LR,
    default_max_retry=0
  ];

  // --- Entry / Exit ---
  Start    [shape=Mdiamond, label="Start"];
  Exit     [shape=Msquare,  label="Exit"];
  FailSink [
    shape=box,
    label="Failure Report",
    prompt="A conformance test phase failed. Summarize the failure from context. Do not read or modify any files. Return outcome=success."
  ];
  FailSink -> Exit;

  // ---------------------------------------------------------------
  // Phase 1 — Linear flow with variable expansion
  // Validates: start node routing, prompt attribute, $goal expansion,
  //            unconditional edges, chained edge syntax.
  // ---------------------------------------------------------------
  Analyze [
    shape=box,
    label="Analyze Goal",
    prompt="You are a conformance test. The pipeline goal is: $goal. Acknowledge the goal briefly in one paragraph. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  Start -> Analyze;
  Analyze -> Branch          [condition="outcome=success"];
  Analyze -> FailSink        [condition="outcome=fail", label="phase1_fail"];

  // ---------------------------------------------------------------
  // Phase 2 — Conditional branching
  // Validates: condition expressions (outcome=success, outcome=fail),
  //            edge labels, deterministic edge selection.
  // ---------------------------------------------------------------
  Branch [
    shape=box,
    label="Branch Test",
    prompt="This is a conformance test for conditional branching. Do not use any tools. Do not read or modify any files. Simply return outcome=success."
  ];

  BranchSuccessTarget [
    shape=box,
    label="Success Path",
    prompt="You reached the success path via conditional routing. Confirm in one sentence. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  BranchFailTarget [
    shape=box,
    label="Fail Path",
    prompt="You reached the fail path via conditional routing. Confirm in one sentence. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  Branch -> BranchSuccessTarget [condition="outcome=success", label="pass"];
  Branch -> BranchFailTarget    [condition="outcome=fail",    label="fail"];

  // Both paths converge on the next phase.
  BranchSuccessTarget -> GoalGateSetup [condition="outcome=success"];
  BranchSuccessTarget -> FailSink      [condition="outcome=fail", label="phase2_fail"];
  BranchFailTarget    -> GoalGateSetup [condition="outcome=success"];
  BranchFailTarget    -> FailSink      [condition="outcome=fail", label="phase2_fail"];

  // ---------------------------------------------------------------
  // Phase 3 — Goal gate with retry loop
  // Validates: goal_gate=true enforcement, retry_target routing,
  //            max_retries limit, outcome=retry edge.
  // ---------------------------------------------------------------
  GoalGateSetup [
    shape=box,
    label="Goal Gate Setup",
    prompt="Prepare for the goal gate test. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  GoalGate [
    shape=box,
    label="Goal Gate",
    goal_gate=true,
    max_retries=1,
    retry_target="GoalGateSetup",
    prompt="This is a goal gate conformance test. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  GoalGateSetup -> GoalGate   [condition="outcome=success"];
  GoalGateSetup -> FailSink   [condition="outcome=fail", label="phase3_fail"];
  GoalGate -> ParallelSetup   [condition="outcome=success", label="gate_pass"];
  GoalGate -> GoalGateSetup   [condition="outcome=retry",   label="gate_retry"];
  GoalGate -> FailSink        [condition="outcome=fail",     label="phase3_fail"];

  // ---------------------------------------------------------------
  // Phase 4 — Parallel fan-out / fan-in
  // Validates: component (fan-out) handler, tripleoctagon (fan-in)
  //            handler, concurrent branch execution, result merging.
  // ---------------------------------------------------------------
  ParallelSetup [shape=component, label="Parallel Branches"];

  BranchAlpha [
    shape=box,
    label="Branch Alpha",
    prompt="You are branch Alpha of a parallel fan-out. Confirm in one sentence. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  BranchBeta [
    shape=box,
    label="Branch Beta",
    prompt="You are branch Beta of a parallel fan-out. Confirm in one sentence. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  BranchGamma [
    shape=box,
    label="Branch Gamma",
    prompt="You are branch Gamma of a parallel fan-out. Confirm in one sentence. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  ParallelJoin [shape=tripleoctagon, label="Parallel Join"];

  ParallelSetup -> BranchAlpha;
  ParallelSetup -> BranchBeta;
  ParallelSetup -> BranchGamma;
  BranchAlpha -> ParallelJoin;
  BranchBeta  -> ParallelJoin;
  BranchGamma -> ParallelJoin;

  // ---------------------------------------------------------------
  // Phase 5 — Context propagation and edge weight
  // Validates: context values flow downstream, weight-based edge
  //            selection among unconditional edges, max_retries
  //            attribute on individual nodes.
  // ---------------------------------------------------------------
  ContextCheck [
    shape=box,
    label="Context Verification",
    max_retries=0,
    prompt="Verify that context from all three parallel branches (Alpha, Beta, Gamma) is available. Summarize briefly. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  WeightedA [
    shape=box,
    label="Low Weight Target",
    prompt="You reached the low-weight edge target. Confirm in one sentence. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  WeightedB [
    shape=box,
    label="High Weight Target",
    prompt="You reached the high-weight edge target (expected path). Confirm in one sentence. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  ParallelJoin -> ContextCheck;
  ContextCheck -> WeightedA [condition="outcome=success", weight=1];
  ContextCheck -> WeightedB [condition="outcome=success", weight=10];
  ContextCheck -> FailSink  [condition="outcome=fail", label="phase5_fail"];

  // ---------------------------------------------------------------
  // Phase 6 — Final summary
  // Validates: multi-hop traversal, pipeline completion, exit node
  //            reached cleanly.
  // ---------------------------------------------------------------
  Summary [
    shape=box,
    label="Conformance Summary",
    prompt="The conformance test exercised: linear flow, $goal expansion, conditional branching, goal gates with retry, parallel fan-out/fan-in, context propagation, and weighted edge selection. Summarize in one paragraph. Do not use any tools. Do not read or modify any files. Return outcome=success."
  ];

  WeightedA -> Summary;
  WeightedB -> Summary;
  Summary   -> Exit [condition="outcome=success"];
  Summary   -> FailSink [condition="outcome=fail", label="phase6_fail"];
}
