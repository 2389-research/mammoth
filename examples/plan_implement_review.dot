// ABOUTME: Example pipeline demonstrating a simple plan → implement → review flow.
// Used by the attractor integration test TestIntegrationPlanImplementReview.
digraph PlanImplementReview {
  graph [
    label="Plan Implement Review",
    goal="Create a hello world Python script",
    rankdir=LR
  ];

  start     [shape=Mdiamond, label="Start"];
  done      [shape=Msquare,  label="Done"];

  plan [
    shape=box,
    label="Plan",
    prompt="Write a concise implementation plan for the goal."
  ];

  implement [
    shape=box,
    label="Implement",
    goal_gate=true,
    prompt="Implement the plan. Produce the code."
  ];

  review [
    shape=box,
    label="Review",
    prompt="Review the implementation for correctness and completeness."
  ];

  start     -> plan;
  plan      -> implement;
  implement -> review     [condition="outcome=success", label="pass"];
  implement -> plan       [condition="outcome=retry",   label="retry"];
  review    -> done       [condition="outcome=success", label="pass"];
  review    -> implement  [condition="outcome=retry",   label="retry"];
}
